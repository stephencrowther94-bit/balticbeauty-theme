{% if template.name == 'blog' %}
  <h1 class="visually-hidden">{{ blog.title }}</h1>
{% endif %}
{% if template.name == 'page' %}
  <h1 class="visually-hidden">{{ page.title }}</h1>
{% endif %}
{% if template.name == 'index' %}
  <h1 class="visually-hidden">{{ shop.name }}{% if page_description != blank %} — {{ page_description | strip_html | truncate: 100 }}{% endif %}</h1>
{% endif %}
{% if template.name == 'article' %}
  <h1 class="visually-hidden">{{ article.title | default: page.title }}</h1>
{% endif %}

<link rel="stylesheet" data-href="https://use.typekit.net/cwy2ysj.css">
<link rel="preload" href="{{ 'splide.min.js' | asset_url }}" as="script">
