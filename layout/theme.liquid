    klaviyo.init({
      account: "RkbZRd",
       list: 'SZXCRM',
      platform: "shopify"
    });
    klaviyo.enable("backinstock",{ 
    trigger: {
      product_page_text: "Notify when back in stock",
      product_page_class: "btn btn--solid  btn--primary",
      product_page_text_align: "center",
