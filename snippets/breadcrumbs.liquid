{% assign breadcrumbs_modifier = breadcrumbs_modifier | default: '' %}

{% capture divider_html %}
  <span class="breadcrumbs__arrow" aria-hidden="true">&nbsp;</span>
{% endcapture %}

<nav class="breadcrumbs {{ breadcrumbs_modifier }}" aria-label="{{ 'general.breadcrumbs.title' | t | default: 'Breadcrumb' }}">
  <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t }}</a>

  {{ divider_html }}

  {% if template contains 'product' %}
    {%- if collection -%}
      {{ collection.title | link_to: collection.url }}

      {{ divider_html }}
    {%- endif -%}
  {%- elsif template.name == 'article' -%}
    {{ blog.title | link_to: blog.url }}

    {{ divider_html }}
  {% endif %}

  <span aria-current="page">{{- page_title -}}</span>
</nav>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'general.breadcrumbs.home' | t | json }},
      "item": {{ shop.url | append: routes.root_url | json }}
    }
    {%- if template contains 'product' and collection -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ shop.url | append: collection.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ shop.url | append: product.url | json }}
      }
    {%- elsif template contains 'product' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": {{ shop.url | append: product.url | json }}
      }
    {%- elsif template contains 'collection' and collection -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ shop.url | append: collection.url | json }}
      }
    {%- elsif template.name == 'article' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ shop.url | append: blog.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ article.title | json }},
        "item": {{ shop.url | append: article.url | json }}
      }
    {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ page_title | json }},
        "item": {{ canonical_url | json }}
      }
    {%- endif -%}
  ]
}
</script>